{
  "name": "nanoka-genshin-scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Scrape et post-traitement des données Genshin Impact depuis gi.nanoka.cc",
  "scripts": {
    "test": "cd backend && pytest",
    "test:verbose": "cd backend && pytest -v",
    "test:cov": "cd backend && pytest --cov=nanoka --cov-report=term-missing",
    "test:web": "npm test --prefix frontend",
    "test:web:cov": "npm run test:cov --prefix frontend",
    "scrape": "cd backend && python -m nanoka.scrape",
    "scrape:quick": "cd backend && python -m nanoka.scrape --max-characters 3 --max-weapons 3 --max-items 20 --skip-image-download",
    "assign": "cd backend && python -m nanoka.assign",
    "report:characters": "cd backend && python -m nanoka.ascension_report --print",
    "report:weapons": "cd backend && python -m nanoka.weapon_report",
    "report:talents": "cd backend && python -m nanoka.talent_report",
    "migrate:paths": "cd backend && python -m nanoka.migrate_paths",
    "docker:build": "docker compose -f backend/deploy/docker-compose.yml build",
    "docker:scrape": "docker compose -f backend/deploy/docker-compose.yml run --rm scrape",
    "docker:assign": "docker compose -f backend/deploy/docker-compose.yml run --rm pipeline -m nanoka.assign",
    "docker:report:characters": "docker compose -f backend/deploy/docker-compose.yml run --rm pipeline -m nanoka.ascension_report --print",
    "docker:report:weapons": "docker compose -f backend/deploy/docker-compose.yml run --rm pipeline -m nanoka.weapon_report",
    "docker:report:talents": "docker compose -f backend/deploy/docker-compose.yml run --rm pipeline -m nanoka.talent_report",
    "docker:full": "docker compose -f backend/deploy/docker-compose.yml --profile full up scrape post-process",
    "docker:api": "docker compose -f backend/deploy/docker-compose.yml --profile runtime up api",
    "docker:stack:up": "docker compose -f deploy/docker-compose.stack.yml up -d --build",
    "docker:stack:down": "docker compose -f deploy/docker-compose.stack.yml down",
    "docker:web:build": "docker compose -f frontend/deploy/docker-compose.yml build",
    "docker:web:up": "docker compose -f frontend/deploy/docker-compose.yml up -d",
    "docker:web:down": "docker compose -f frontend/deploy/docker-compose.yml down",
    "security": "trivy fs --config backend/config/trivy/trivy.yaml backend",
    "security:scan": "powershell -NoProfile -ExecutionPolicy Bypass -File backend/scripts/trivy-scan.ps1",
    "security:web": "trivy fs --config frontend/config/trivy/trivy.yaml frontend",
    "security:web:scan": "powershell -NoProfile -ExecutionPolicy Bypass -File frontend/scripts/trivy-scan.ps1",
    "dev:api": "cd backend && python -m uvicorn nanoka.api:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "npm run dev --prefix frontend",
    "build:web": "npm run build --prefix frontend"
  },
  "engines": {
    "node": ">=18"
  }
}
